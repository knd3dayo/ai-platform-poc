# LLM settings for Super-Visor (required)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
# If using LiteLLM (infra/05-litellm) on ai_platform_internal network
LLM_BASE_URL=http://litellm:4000

# Optional: override LLM base URL passed into executor container
# (useful when executor container must reach LLM via internal network address)
LLM_BASE_URL_IN_CONTAINER=

# Executor compose template inside this image (usually keep defaults)
COMPOSE_DIRECTORY=/opt/ai-platform/autonomous-agent-executor/all-in-on-image
COMPOSE_FILE=docker-compose.yml
COMPOSE_SERVICE_NAME=all-in-one-code-executor

# Workspace root inside this container (must be mirrored on host for DoOD)
WORKSPACE_ROOT=/srv/ai_platform/workspaces

# Optional: change the executor command
# COMPOSE_COMMAND="opencode run"
# COMPOSE_COMMAND="claude --dangerously-skip-permissions -p"
# COMPOSE_COMMAND="cline -y"

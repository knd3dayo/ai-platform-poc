ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=
# OIDC_TEST_APPLICATION_KEY_PATH=/absolute/path/to/service-account-key.json
# OIDC_TEST_INTROSPECTION_APPLICATION_KEY_PATH=/absolute/path/to/application-introspection-key.json
# OIDC_TEST_APPLICATION_KEY_JSON={"type":"application/json","keyId":"...","key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","clientId":"...","appId":"..."}
# OIDC_TEST_APPLICATION_KEY_B64=
# Service account example: {"type":"serviceaccount","keyId":"...","key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","userId":"..."}
# Validated setup for this PoC:
# - switch the service account Access Token Type to JWT in ZITADEL
# - use the service account key as OIDC_TEST_APPLICATION_KEY_PATH
# - expected audience and default scopes are defined in config.yml
# OIDC_TEST_APPLICATION_KEY_PATH=/home/user/source/repos/ai-platform-poc/infra/91-zitadel/365508380967567366.json
# OIDC_TEST_AUDIENCE=365171666990530564

# If you keep opaque access tokens instead of JWT:
# - request the audience scope of the target project
# - use an introspection client that is part of that token audience
# OIDC_TEST_SCOPES=openid,profile,urn:zitadel:iam:org:project:id:<project-id>:aud

# Optional overrides
# OIDC_TEST_AUDIENCE=
# OIDC_TEST_AUDIENCES=client-id-1,client-id-2
# OIDC_TEST_SCOPES=scope1,scope2
# OIDC_TEST_CONFIG=/absolute/path/to/config.yml
# OIDC_TEST_SERVER_BASE_URL=http://localhost:5801

# Sample server endpoints:
# - /protected/me: validate the bearer token locally
# - /protected/authorize/client: sample claim-based authorization by client_id
# - /protected/authorize/scope: sample scope-based authorization when scope claims are present
# - /protected/forward/backend: forward the bearer token from the BFF to the separate backend server
# Separate backend server:
# - start BFF with: python -m ai_platform_samplelib.oidc.server --port 5801
# - start backend with: python -m ai_platform_samplelib.oidc.backend_server --port 5802